{
  "name": "modviz",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "bin": {
    "modviz": "./dist/cli.js"
  },
  "scripts": {
    "cli": "node mod/cli.ts",
    "cli:build": "tsc mod/cli.ts --outDir dist --target es2022 --module nodenext --moduleResolution nodenext",
    "fmt": "biome format --fix",
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "@react-sigma/core": "^5.0.4",
    "@react-sigma/graph-search": "^5.0.4",
    "@react-sigma/layout-circlepack": "^5.0.4",
    "@react-sigma/layout-circular": "^5.0.4",
    "@react-sigma/layout-core": "^5.0.4",
    "@react-sigma/layout-force": "^5.0.4",
    "@react-sigma/layout-forceatlas2": "^5.0.4",
    "@react-sigma/layout-noverlap": "^5.0.4",
    "@react-sigma/layout-random": "^5.0.4",
    "@react-sigma/minimap": "^5.0.5",
    "@sigma/utils": "^3.0.0",
    "@tanstack/react-router": "^1.131.40",
    "@tanstack/react-router-devtools": "^1.131.40",
    "@tanstack/react-start": "^1.131.40",
    "@thepassle/module-graph": "^0.12.0",
    "find-workspaces": "^0.3.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-generators": "^0.11.2",
    "graphology-types": "^0.24.8",
    "iwanthue": "^2.0.0",
    "leva": "^0.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "seedrandom": "^3.0.5",
    "sigma": "^3.0.2",
    "tailwind-merge": "^2.6.0",
    "tsconfck": "^3.1.6",
    "vite": "^6.3.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
