{
  "name": "modviz",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "bin": {
    "modviz": "./dist/cli.js"
  },
  "scripts": {
    "cli": "node mod/cli.ts",
    "cli:build": "tsc mod/cli.ts --outDir dist --target es2022 --module nodenext --moduleResolution nodenext",
    "fmt": "biome format --fix",
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.131.40",
    "@tanstack/react-router-devtools": "^1.131.40",
    "@tanstack/react-start": "^1.131.40",
    "@thepassle/module-graph": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reagraph": "^4.30.4",
    "tailwind-merge": "^2.6.0",
    "vite": "^6.3.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
