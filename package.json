{
  "name": "modviz",
  "private": true,
  "bin": {
    "modviz": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "cli": "node mod/cli.ts",
    "build:runtime": "vite build && node ./scripts/build-runtime.mjs",
    "cli:build": "tsgo --ignoreConfig --skipLibCheck mod/cli.ts --outDir dist --target es2022 --module nodenext --moduleResolution nodenext --allowImportingTsExtensions --rewriteRelativeImportExtensions",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint --import-plugin --react-plugin --vitest-plugin --jsx-a11y-plugin --node-plugin .",
    "lint:fix": "pnpm run lint -- --fix",
    "dev": "vite dev",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsgo": "tsgo -config tsconfig.json",
    "check": "pnpm run lint && pnpm run typecheck",
    "build": "pnpm run build:runtime && pnpm run cli:build && pnpm run typecheck",
    "prepack": "pnpm run build",
    "start": "node dist/runtime/server/index.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@ark-ui/react": "^5.35.0",
    "@astahmer/module-graph": "0.14.1",
    "@chenglou/pretext": "^0.0.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-sigma/core": "^5.0.6",
    "@react-sigma/graph-search": "^5.0.6",
    "@react-sigma/layout-circlepack": "^5.0.6",
    "@react-sigma/layout-circular": "^5.0.6",
    "@react-sigma/layout-core": "^5.0.6",
    "@react-sigma/layout-force": "^5.0.6",
    "@react-sigma/layout-forceatlas2": "^5.0.6",
    "@react-sigma/layout-noverlap": "^5.0.6",
    "@react-sigma/layout-random": "^5.0.6",
    "@react-sigma/minimap": "^5.0.6",
    "@sigma/utils": "^3.0.0",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/react-virtual": "^3.13.23",
    "@xstate/store": "^3.17.1",
    "ai": "^6.0.142",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "find-workspaces": "^0.3.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-types": "^0.24.8",
    "iwanthue": "^2.0.0",
    "leva": "^0.10.1",
    "lucide-react": "^1.7.0",
    "magic-string": "^0.30.21",
    "nanovis": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "resolve-pkg-maps": "^1.0.0",
    "sigma": "^3.0.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.8",
    "shadcn": "4.1.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
